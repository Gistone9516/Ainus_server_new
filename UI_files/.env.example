# API Configuration
# 개발 환경: localhost (에뮬레이터) 또는 로컬 IP (실제 디바이스)
# iOS 시뮬레이터: http://localhost:3000/api/v1
# Android 에뮬레이터: http://10.0.2.2:3000/api/v1
# 실제 디바이스: http://<YOUR_LOCAL_IP>:3000/api/v1 (예: http://192.168.0.10:3000/api/v1)
EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1

# 앱 설정
EXPO_PUBLIC_APP_NAME=Ainus
EXPO_PUBLIC_APP_VERSION=1.0.0
